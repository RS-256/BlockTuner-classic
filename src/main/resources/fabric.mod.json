{
  "schemaVersion": 1,
  "id": "blocktuner",
  "version": "${version}",

  "name": "BlockTuner",
  "description": "A mod which helps you tune note blocks.",
  "authors": [
    "xwjcool",
    "Lumine1909",
    "RS256"
  ],
  "contact": {
    "sources": "https://github.com/Lumine1909/BlockTunerMod_Continue"
  },

  "license": "LGPLv3",
  "icon": "assets/blocktuner/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "com.rs256.blocktuner.BlockTuner"
    ],
    "client": [
      "com.rs256.blocktuner.BlockTunerClient"
    ]
  },
  "mixins": [
    "blocktuner.mixins.json"
  ],
  "accessWidener": "blocktuner.accesswidener",

  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric": "*",
    "minecraft": "${minecraft}"
  },
  "conflicts": {
    "noteduplicator": "*",
    "tweakeroo": "*"
  }
}
