{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",

  "name": "${name}",
  "description": "A mod which helps you tune note blocks.",
  "authors": [
    "xwjcool",
    "Lumine1909",
    "RS256"
  ],
  "contact": {
    "sources": "https://github.com/Lumine1909/BlockTunerMod_Continue"
  },

  "license": "LGPLv3",
  "icon": "assets/blocktuner/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "com.rs256.blocktuner.BlockTuner"
    ],
    "client": [
      "com.rs256.blocktuner.BlockTunerClient"
    ],
    "modmenu": [
      "com.rs256.blocktuner.config.BlockTunerModMenuIntegration"
    ]
  },
  "mixins": [
    "blocktuner.mixins.json",
    {
      "config": "blocktunerClient.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "${accesswidener}",

  "depends": {
    "fabricloader": "${fabricLoader}",
    "${fabricApiKey}": "${fabricAPI}",
    "minecraft": "${minecraft}",
    "yet_another_config_lib_v3": ">=3.8.2"
  },
  "conflicts": {
    "noteduplicator": "*",
    "tweakeroo": "*"
  }
}
